# Server Configuration
NODE_ENV=development
PORT=3000
API_VERSION=v1

# Security
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# CORS
CORS_ORIGIN=http://localhost:3001,http://localhost:3002
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3002

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Database - PostgreSQL
DATABASE_URL=postgresql://admin:changeme@localhost:5432/ambulance_dispatch
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ambulance_dispatch
DB_USER=admin
DB_PASSWORD=changeme
DB_MAX_POOL=20
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=2000

# Redis Cache
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=3600

# Logging
LOG_LEVEL=info
LOG_DIR=logs

# External Services
GEOCODING_API_KEY=your-geocoding-api-key
MAPS_API_KEY=your-maps-api-key
SMS_API_KEY=your-sms-api-key
NOTIFICATION_SERVICE_URL=http://localhost:3005

# Monitoring
METRICS_ENABLED=true
HEALTH_CHECK_INTERVAL=30000

# Service URLs (Microservices)
INCIDENT_SERVICE_URL=http://localhost:3010
AMBULANCE_SERVICE_URL=http://localhost:3011
HOSPITAL_SERVICE_URL=http://localhost:3012
TRACKING_SERVICE_URL=http://localhost:3013
ANALYTICS_SERVICE_URL=http://localhost:3014
