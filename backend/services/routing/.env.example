# Routing Service Environment Variables

# OSRM Configuration
OSRM_URL=http://localhost:5000

# Redis Configuration (for route caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_ROUTING_DB=2

# Cache Settings
ROUTE_CACHE_TTL=300  # Cache duration in seconds (5 minutes)

# Traffic Integration (Optional - for production)
# GOOGLE_MAPS_API_KEY=your_google_maps_api_key
# TOMTOM_API_KEY=your_tomtom_api_key
# HERE_API_KEY=your_here_api_key

# Performance Tuning
OSRM_MAX_TABLE_SIZE=10000
BATCH_ROUTING_MAX_REQUESTS=50
ROUTE_SIMPLIFICATION_TOLERANCE=0.0001

# Fallback Settings
FALLBACK_URBAN_SPEED_KMH=30
FALLBACK_SUBURBAN_SPEED_KMH=45
FALLBACK_HIGHWAY_SPEED_KMH=65
FALLBACK_ROAD_FACTOR_URBAN=1.4
FALLBACK_ROAD_FACTOR_SUBURBAN=1.3
FALLBACK_ROAD_FACTOR_HIGHWAY=1.2
