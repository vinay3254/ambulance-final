{
  "name": "@ambulance-dispatch/ussd-service",
  "version": "1.0.0",
  "description": "USSD Menu System for rural/low-connectivity ambulance dispatch",
  "main": "ussd-server.js",
  "scripts": {
    "start": "node ussd-server.js",
    "dev": "nodemon ussd-server.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test:integration": "jest --testPathPattern=integration",
    "test:unit": "jest --testPathPattern=unit"
  },
  "keywords": [
    "ussd",
    "ambulance",
    "dispatch",
    "sms",
    "emergency",
    "rural",
    "low-connectivity",
    "cell-tower",
    "location"
  ],
  "author": "Ambulance Dispatch Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "redis": "^4.6.7",
    "axios": "^1.4.0",
    "uuid": "^9.0.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "nodemon": "^3.0.1",
    "eslint": "^8.48.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.28.1"
  },
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ambulance-dispatch/ussd-service.git"
  },
  "bugs": {
    "url": "https://github.com/ambulance-dispatch/ussd-service/issues"
  },
  "homepage": "https://github.com/ambulance-dispatch/ussd-service#readme",
  "jest": {
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "/node_modules/"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ]
  },
  "eslintConfig": {
    "extends": "airbnb-base",
    "env": {
      "node": true,
      "jest": true
    },
    "rules": {
      "no-console": "off",
      "func-names": "off"
    }
  }
}
