# Database Configuration
DB_PASSWORD=your_secure_password_here
DATABASE_URL=postgresql://admin:your_secure_password_here@postgres:5432/ambulance_dispatch
MAX_POOL_SIZE=20

# Redis Configuration
REDIS_URL=redis://redis:6379

# OSRM Configuration
OSRM_URL=http://osrm:5000

# JWT Configuration
JWT_SECRET=your_jwt_secret_min_32_chars_change_in_production
JWT_EXPIRES_IN=12h

# CORS Configuration
CORS_ORIGIN=https://yourdomain.com

# Application Configuration
NODE_ENV=production
LOG_LEVEL=info
PORT=3000

# Frontend Configuration
REACT_APP_API_URL=https://api.yourdomain.com
REACT_APP_WS_URL=wss://ws.yourdomain.com

# Docker Registry (for production)
DOCKER_REGISTRY=your-registry.com/ambulance
IMAGE_TAG=latest

# Monitoring & Error Tracking
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# SSL/TLS Configuration
SSL_CERT_EMAIL=admin@yourdomain.com
DOMAIN=yourdomain.com

# Backup Configuration
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=ambulance-backups
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Cache TTL (seconds)
CACHE_TTL_AMBULANCE_LOCATION=30
CACHE_TTL_ROUTE=300
CACHE_TTL_HOSPITAL=3600
